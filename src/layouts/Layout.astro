---
import '../styles/global.css';
import { categoryRepository } from '../repositories/category.repository';
import type { Category } from '../types';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Modern e-shop built with Astro and Tailwind CSS", 
	image = "/og-image.png" 
} = Astro.props;

const canonicalURL = Astro.site 
	? new URL(Astro.url.pathname, Astro.site) 
	: new URL(Astro.url.pathname, Astro.url.origin);

const allCategories = await categoryRepository.findAll();
const mainCategories = allCategories.filter((c: Category) => !c.parentId);

const GTM_ID = import.meta.env.PUBLIC_GTM_ID;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- GTM Head -->
		{GTM_ID && (
			<script is:inline define:vars={{ GTM_ID }}>
				(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
				new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
				j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
				'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
				})(window,document,'script','dataLayer',GTM_ID);
			</script>
		)}

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- GTM Body -->
		{GTM_ID && (
			<noscript>
				<iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
				height="0" width="0" style="display:none;visibility:hidden"></iframe>
			</noscript>
		)}
		<nav id="main-nav" class="fixed top-0 w-full z-50 glass border-b border-white/5 py-4 px-6">
			<div class="max-w-7xl mx-auto flex justify-between items-center">
				<a href="/" class="text-2xl font-display font-black gradient-text">ASTRO SHOP</a>
				<div class="hidden md:flex gap-8 items-center font-medium">
					<a href="/products" class="hover:text-primary transition-colors">Products</a>
					
					<div class="group relative py-2">
						<a href="/categories" class="hover:text-primary transition-colors flex items-center gap-1">
							Categories
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:rotate-180 transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
						</a>
						<div class="absolute top-full left-0 pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-300 ease-out z-50">
							<div class="glass min-w-[240px] p-2 rounded-xl border border-white/10 shadow-2xl backdrop-blur-xl">
								<div class="grid grid-cols-1 gap-1">
									{mainCategories.map((category: Category) => (
										<a href={`/categories/${category.slug}`} class="px-4 py-2.5 rounded-lg hover:bg-white/10 transition-colors text-sm font-medium whitespace-nowrap">
											{category.name}
										</a>
									))}
								</div>
								<div class="mt-2 pt-2 border-t border-white/5">
									<a href="/categories" class="block px-4 py-2 text-xs text-on-surface/50 hover:text-primary transition-colors text-center italic">
										View All Categories →
									</a>
								</div>
							</div>
						</div>
					</div>
					<a href="/about" class="hover:text-primary transition-colors">About</a>
					<a href="/checkout" id="cart-nav-link" class="premium-btn py-2 px-6 text-sm flex items-center gap-2">
						<span>Cart</span>
						<span id="cart-count" class="bg-white/20 px-2 rounded-full min-w-[20px] text-center">0</span>
					</a>
				</div>
			</div>
		</nav>

		<script>
			import { cartStore } from '../lib/stores/cart';
			
			const cartCount = document.getElementById('cart-count');
			
			if (cartCount) {
				cartStore.subscribe((cart) => {
					const count = Object.values(cart).reduce((acc, item) => acc + item.quantity, 0);
					cartCount.textContent = count.toString();
				});
			}
		</script>

		<main id="content" class="flex-grow pt-24">
			<slot />
		</main>

		<footer class="glass mt-24 py-12 px-6">
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
				<div>
					<h3 class="text-xl mb-4 gradient-text">ASTRO SHOP</h3>
					<p class="text-on-surface/60 max-w-xs">Elevating your shopping experience with the power of lightning-fast web technologies.</p>
				</div>
				<div>
					<h4 class="mb-4">Quick Links</h4>
					<ul class="space-y-2 text-on-surface/60">
						<li><a href="/terms" class="hover:text-primary">Terms of Service</a></li>
						<li><a href="/privacy" class="hover:text-primary">Privacy Policy</a></li>
						<li><a href="/shipping" class="hover:text-primary">Shipping Info</a></li>
					</ul>
				</div>
				<div>
					<h4 class="mb-4">Newsletter</h4>
					<div class="flex gap-2">
						<input type="email" placeholder="Email address" class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 flex-grow focus:outline-none focus:border-primary" />
						<button class="bg-primary px-4 py-2 rounded-lg font-bold">Join</button>
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-white/5 text-center text-on-surface/40 text-sm">
				© {new Date().getFullYear()} Astro Shop. All rights reserved.
			</div>
		</footer>
	</body>
</html>
