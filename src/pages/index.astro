---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/shop/CategoryCard.astro';
import ProductCard from '../components/shop/ProductCard.astro';
import { categoryRepository } from '../repositories/category.repository';
import { productRepository } from '../repositories/product.repository';
import type { Category, ProductWithCategory } from '../types';

const categories = await categoryRepository.findAll() as Category[];
const randomProducts = await productRepository.getRandom(6) as ProductWithCategory[];
---

<Layout title="Astro Shop | Premium E-Commerce Experience">
	<section class="relative h-[80vh] flex items-center justify-center overflow-hidden">
		<!-- Mesh Gradient Background -->
		<div class="absolute inset-0 -z-10 bg-surface">
			<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/20 blur-[120px] rounded-full animate-float"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/20 blur-[120px] rounded-full animate-float" style="animation-delay: -3s"></div>
		</div>

		<div class="max-w-4xl px-6 text-center space-y-8">
			<h1 class="text-6xl md:text-8xl font-black tracking-tight leading-tight">
				Budoucnost <span class="gradient-text">nakupování</span> začíná zde
			</h1>
			<p class="text-xl md:text-2xl text-on-surface/70 max-w-2xl mx-auto leading-relaxed">
				Vyzkoušejte nejrychlejší e-shop platformu postavenou na moderních technologiích. 
				Špičkový výkon, prémiový design a intuitivní UX.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center pt-8">
				<a href="/products" class="premium-btn text-lg">Prozkoumat kolekci</a>
				<a href="/categories" class="px-8 py-3 rounded-full border border-white/20 hover:bg-white/5 transition-colors font-bold text-lg">Procházet kategorie</a>
			</div>
		</div>
	</section>

	{/* Category Section */}
	<section class="max-w-7xl mx-auto px-6 py-24 border-t border-white/5">
		<div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-12 gap-6 text-center md:text-left">
			<div>
				<h2 class="text-4xl font-bold uppercase tracking-tighter">Top <span class="gradient-text">Kategorie</span></h2>
				<p class="text-on-surface/60 mt-2">Objevte naše hlavní produktové řady.</p>
			</div>
			<a href="/categories" class="text-primary font-bold hover:underline uppercase tracking-widest text-sm">Všechny kategorie →</a>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{categories.slice(0, 3).map(category => (
				<CategoryCard category={category} />
			))}
		</div>
	</section>

	{/* Random Products Section */}
	<section class="max-w-7xl mx-auto px-6 py-24 bg-white/2 rounded-[4rem] border border-white/5">
		<div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-12 gap-6 text-center md:text-left">
			<div>
				<h2 class="text-4xl font-bold uppercase tracking-tighter">Vybráno <span class="gradient-text">pro vás</span></h2>
				<p class="text-on-surface/60 mt-2">Náhodný výběr z naší prémiové kolekce.</p>
			</div>
			<a href="/products" class="text-primary font-bold hover:underline uppercase tracking-widest text-sm">Zobrazit vše →</a>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{randomProducts.map(product => (
				<ProductCard product={product} />
			))}
		</div>
	</section>
</Layout>

<script>
	import { gsap } from 'gsap';

	// Simple entry animation
	window.addEventListener('DOMContentLoaded', () => {
		gsap.from('h1', { 
			y: 50, 
			opacity: 0, 
			duration: 1, 
			ease: 'power4.out',
			delay: 0.2
		});
		
		gsap.from('p', { 
			y: 30, 
			opacity: 0, 
			duration: 1, 
			ease: 'power3.out',
			delay: 0.4
		});

		gsap.from('main .premium-btn, a[href="/about"]', { 
			y: 20, 
			opacity: 0, 
			duration: 0.8, 
			stagger: 0.1,
			ease: 'back.out(1.7)',
			delay: 0.6
		});
	});
</script>
