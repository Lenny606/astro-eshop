---
import Layout from '../../layouts/Layout.astro';
import Price from '../../components/ui/Price.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import { productRepository } from '../../repositories/product.repository';
import type { ProductWithCategory } from '../../types';

export async function getStaticPaths() {
  const products = await productRepository.findAll();
  return products.map((product: any) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = await productRepository.findBySlug(slug!) as ProductWithCategory;

if (!product) {
  return Astro.redirect('/404');
}

const { name, price, stock, description, image, category } = product;
const isOutOfStock = stock <= 0;
---

<Layout title={`${name} | Premium Shop`} description={description}>
  <div class="container mx-auto px-4 py-32">
    {/* Breadcrumbs */}
    <nav class="flex mb-8 text-sm text-on-surface/40 uppercase tracking-widest font-bold" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-primary transition-colors">Domů</a></li>
        <li><span class="mx-2">/</span></li>
        <li><a href="/products" class="hover:text-primary transition-colors">Produkty</a></li>
        {category && (
          <>
            <li><span class="mx-2">/</span></li>
            <li><a href={`/category/${category.slug}`} class="hover:text-primary transition-colors">{category.name}</a></li>
          </>
        )}
        <li><span class="mx-2 text-primary">/</span></li>
        <li class="text-on-surface/60 truncate max-w-[200px]">{name}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      {/* Left: Image Section */}
      <div class="relative group">
        <div class="aspect-square rounded-3xl overflow-hidden glass p-4 border border-white/5 shadow-2xl">
          <img 
            src={image || 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1200&auto=format&fit=crop'} 
            alt={name}
            class="w-full h-full object-cover rounded-2xl transition-transform duration-700 group-hover:scale-105"
          />
        </div>
        
        {/* Glow Effect */}
        <div class="absolute -inset-4 bg-primary/20 blur-3xl -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

        {isOutOfStock && (
          <div class="absolute inset-4 z-10 flex items-center justify-center bg-black/60 backdrop-blur-md rounded-2xl">
            <Badge variant="outline" class="text-xl px-8 py-3 uppercase tracking-[0.3em]">Momentálně nedostupné</Badge>
          </div>
        )}
      </div>

      {/* Right: Info Section */}
      <div class="flex flex-col">
        {category && (
          <div class="mb-4">
            <Badge variant="glass" class="text-xs uppercase tracking-widest">{category.name}</Badge>
          </div>
        )}

        <h1 class="text-5xl md:text-6xl font-black mb-4 leading-tight gradient-text">
          {name}
        </h1>

        <div class="flex items-end gap-4 mb-8">
          <Price amount={price} class="text-4xl font-display font-medium text-on-surface" />
          {/* Mock original price for discount look */}
          <span class="text-lg line-through text-on-surface/20 mb-1">
            <Price amount={price * 1.2} />
          </span>
        </div>

        <div class="prose prose-invert mb-10">
          <p class="text-lg text-on-surface/60 leading-relaxed">
            {description}
          </p>
        </div>

        {/* Stock Status */}
        <div class="flex items-center gap-3 mb-10 text-sm font-bold uppercase tracking-widest">
          <span class:list={['h-3 w-3 rounded-full shadow-[0_0_12px] shadow-current', isOutOfStock ? 'text-red-500 bg-red-500' : 'text-primary bg-primary']} />
          <span class={isOutOfStock ? 'text-red-400' : 'text-primary/80'}>
            {isOutOfStock ? 'Není skladem' : `Skladem: ${stock} ks`}
          </span>
        </div>

        {/* Actions */}
        <div class="flex flex-wrap gap-4 items-center">
          <div class="flex items-center glass rounded-xl border border-white/10 p-1">
            <button class="w-12 h-12 flex items-center justify-center hover:text-primary transition-colors font-bold text-xl" id="qty-minus">-</button>
            <input 
              type="number" 
              value="1" 
              min="1" 
              class="w-14 bg-transparent text-center focus:outline-none font-bold text-lg [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" 
              id="qty-input"
            />
            <button class="w-12 h-12 flex items-center justify-center hover:text-primary transition-colors font-bold text-xl" id="qty-plus">+</button>
          </div>

          <Button variant="primary" size="lg" class="flex-grow md:flex-initial px-10 shadow-[0_20px_40px_-15px_rgba(var(--color-primary),0.3)]" disabled={isOutOfStock}>
            {isOutOfStock ? 'Nedostupné' : 'Přidat do košíku'}
          </Button>
        </div>

        {/* Trust Badges / Info */}
        <div class="mt-16 grid grid-cols-2 gap-8 border-t border-white/5 pt-12">
          <div class="flex flex-col gap-2">
            <span class="text-xs text-on-surface/30 font-bold uppercase tracking-tighter">Doprava</span>
            <p class="text-sm font-medium">Zdarma při nákupu nad 2000 Kč</p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="text-xs text-on-surface/30 font-bold uppercase tracking-tighter">Záruka</span>
            <p class="text-sm font-medium">30 dní na vrácení zboží</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const minusBtn = document.getElementById('qty-minus');
  const plusBtn = document.getElementById('qty-plus');
  const input = document.getElementById('qty-input') as HTMLInputElement;

  minusBtn?.addEventListener('click', () => {
    const val = parseInt(input.value);
    if (val > 1) input.value = (val - 1).toString();
  });

  plusBtn?.addEventListener('click', () => {
    input.value = (parseInt(input.value) + 1).toString();
  });
</script>
