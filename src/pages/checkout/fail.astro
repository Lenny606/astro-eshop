---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';

const reason = Astro.url.searchParams.get('reason');
const status = Astro.url.searchParams.get('status');
---

<Layout title="Platba se nezdařila | Astro Shop">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <div class="mb-12">
      <div class="w-24 h-24 bg-red-500/20 text-red-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-[0_0_50px_rgba(239,68,68,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </div>
      <h1 class="text-5xl font-bold mb-4 tracking-tight">Jejda! Platba se nezdařila.</h1>
      <p class="text-xl text-on-surface/60 max-w-lg mx-auto">
        Během zpracování platby došlo k chybě. Žádné peníze nebyly strženy.
      </p>
    </div>

    <div class="glass p-8 rounded-3xl text-left mb-12 border border-white/10 max-w-md mx-auto">
      <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
        Co se mohlo stát?
      </h2>
      <ul class="space-y-3 text-sm text-on-surface/70">
        <li class="flex items-start gap-2">
            <span class="text-primary mt-1">•</span>
            <span>Nedostatek prostředků na účtu.</span>
        </li>
        <li class="flex items-start gap-2">
            <span class="text-primary mt-1">•</span>
            <span>Platba byla zamítnuta vaší bankou.</span>
        </li>
        <li class="flex items-start gap-2">
            <span class="text-primary mt-1">•</span>
            <span>Platnost karty vypršela nebo jsou údaje nesprávné.</span>
        </li>
        <li class="flex items-start gap-2">
            <span class="text-primary mt-1">•</span>
            <span>Relace vypršela nebo byla přerušena.</span>
        </li>
      </ul>
      
      { (reason || status) && (
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-on-surface/30 font-mono uppercase tracking-widest">
            Detail chyby: {reason || status}
        </div>
      )}
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/checkout" variant="primary" size="lg" class="min-w-[200px]">Zkusit znovu zaplatit</Button>
      <Button href="/" variant="ghost" size="lg" class="min-w-[200px]">Zpět na hlavní stránku</Button>
    </div>
  </div>
</Layout>

<style>
    @reference "../../styles/global.css";
</style>
