---
interface Props {
  currentStep: number;
}

const { currentStep } = Astro.props;

const steps = [
  { id: 1, name: 'Košík' },
  { id: 2, name: 'Doprava a platba' },
  { id: 3, name: 'Přehled' },
  { id: 4, name: 'Dokončeno' },
];
---

<div class="w-full py-8">
  <div class="flex items-center justify-between relative max-w-2xl mx-auto px-4">
    {/* Line Background */}
    <div class="absolute top-1/2 left-0 w-full h-0.5 bg-white/10 -translate-y-1/2 -z-10"></div>
    
    {/* Active Line */}
    <div 
      class="absolute top-1/2 left-0 h-0.5 bg-primary -translate-y-1/2 -z-10 transition-all duration-500"
      style={{ width: `${((currentStep - 1) / (steps.length - 1)) * 100}%` }}
    ></div>

    {steps.map((step) => (
      <div class="flex flex-col items-center gap-3">
        <div 
          class:list={[
            "w-10 h-10 rounded-full flex items-center justify-center font-bold transition-all duration-500",
            currentStep >= step.id 
              ? "bg-primary text-primary-content shadow-[0_0_20px_rgba(var(--color-primary),0.3)] scale-110" 
              : "bg-surface text-on-surface/40 border border-white/10"
          ]}
        >
          {step.id}
        </div>
        <span 
          class:list={[
            "text-xs font-medium uppercase tracking-wider transition-colors duration-500",
            currentStep >= step.id ? "text-primary" : "text-on-surface/40"
          ]}
        >
          {step.name}
        </span>
      </div>
    ))}
  </div>
</div>
