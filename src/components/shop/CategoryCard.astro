---
import type { Category } from '../../types';

interface Props {
  category: Category;
  class?: string;
}

const { category, class: className } = Astro.props;
const { name, slug, description } = category;
---

<a 
  href={`/category/${slug}`}
  class:list={[
    'group relative flex flex-col items-center justify-center overflow-hidden rounded-3xl glass p-8 text-center transition-all duration-500 hover:border-primary/40 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2',
    className
  ]}
>
  {/* Background Accent */}
  <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-primary/5 blur-3xl transition-all duration-500 group-hover:bg-primary/10 group-hover:scale-150" />
  
  <div class="relative z-10 flex flex-col items-center">
    {/* Icon or Placeholder */}
    <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/5 border border-white/10 group-hover:bg-primary/10 group-hover:border-primary/20 transition-all duration-500">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-on-surface/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </div>

    <h3 class="mb-2 text-xl font-bold font-display group-hover:text-primary transition-colors">
      {name}
    </h3>
    
    {description && (
      <p class="text-sm text-on-surface/50 line-clamp-2 leading-relaxed">
        {description}
      </p>
    )}
  </div>

  {/* Reveal Arrow */}
  <div class="mt-6 transform transition-all duration-500 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
