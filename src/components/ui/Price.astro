---
interface Props {
  amount: number;
  currency?: string;
  locale?: string;
  class?: string;
}

const { amount, currency = 'CZK', locale = 'cs-CZ', class: className } = Astro.props;

// Amount is stored in minor units (e.g. cents/haléře)
const formattedPrice = new Intl.NumberFormat(locale, {
  style: 'currency',
  currency: currency,
}).format(amount / 100);
---

<span class:list={['font-mono font-bold tracking-tighter', className]}>
  {formattedPrice}
</span>
