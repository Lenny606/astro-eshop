---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'glass';
  class?: string;
}

const { variant = 'primary', class: className } = Astro.props;

const variants = {
  primary: 'bg-accent text-accent-content border-accent',
  secondary: 'bg-secondary text-secondary-content border-secondary',
  outline: 'border-white/20 text-white shadow-sm',
  glass: 'bg-white/5 backdrop-blur-md border border-white/10 text-white shadow-xl',
};
---

<span class:list={[
  'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border transition-all duration-300',
  variants[variant],
  className
]}>
  <slot />
</span>
